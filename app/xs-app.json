{
  "authenticationMethod": "route",
  "routes": [
   
    {
      "source": "^/srv/(.*)$",
      "target": "$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
     {
      "source": "^/test1app/(.*)",
      "target": "$1",
      "localDir": "test1app/",
      "authenticationType": "xsuaa"
    }


  ]
}